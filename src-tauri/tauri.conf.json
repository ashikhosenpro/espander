{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Espander",
  "version": "0.1.0",
  "identifier": "com.ashikhosen.espander",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Espander",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com https://docs.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ASHIK HOSEN",
    "homepage": "https://ashikhosen.com",
    "copyright": "Copyright © 2026 ASHIK HOSEN. All rights reserved.",
    "shortDescription": "Visual manager and sync companion for Espanso.",
    "longDescription": "Espander is a visual manager and sync companion for Espanso snippets, created by ASHIK HOSEN.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "startMenuFolder": "Espander"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
